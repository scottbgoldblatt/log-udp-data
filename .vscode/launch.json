{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug (macOS - CodeLLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": ["192.168.10.5", "25001"],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false
    },
    {
      "name": "Debug (Linux - GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": ["192.168.10.5", "25001"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb"
    },
    {
      "name": "Debug (Windows - MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": ["192.168.10.5", "25001"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false
    }
  ]
}