{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "CMake Debug (macOS - CodeLLDB)",
      "type": "lldb",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopOnEntry": false,
      "osx": {
        "type": "lldb"
      }
    },
    {
      "name": "CMake Debug (Linux - GDB)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "MIMode": "gdb",
      "linux": {
        "MIMode": "gdb"
      }
    },
    {
      "name": "CMake Debug (Windows - MSVC)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "windows": {
        "type": "cppvsdbg"
      }
    }
  ]
}
