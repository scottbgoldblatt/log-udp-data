{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build",
        "-G",
        "Ninja",
        "-DCMAKE_BUILD_TYPE=Debug",
        "-DCMAKE_TOOLCHAIN_FILE=${env:VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "-DVCPKG_TARGET_TRIPLET=${input:vcpkgTriplet}"
      ],
      "problemMatcher": []
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build",
        "--config",
        "Debug",
        "--",
        "-v"
      ],
      "dependsOn": ["CMake: Configure (Debug)"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "vcpkgTriplet",
      "type": "pickString",
      "description": "Select vcpkg triplet for this machine",
      "options": [
        "arm64-osx",
        "x64-osx",
        "x64-linux",
        "x64-windows",
        "x64-windows-static"
      ],
      "default": "arm64-osx"
    }
  ]
}
